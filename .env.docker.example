# 数据库：postgresql（默认）或 sqlite
DB_PROVIDER=postgresql

# PostgreSQL（Docker 默认）
DATABASE_URL=postgres://loj:lojpass@postgres:5432/loj
DB_PASSWORD=lojpass

# SQLite（取消注释下面两行并注释上面 DATABASE_URL）
# DB_PROVIDER=sqlite
# DATABASE_URL=file:./data/loj.db

# Turso（云端 SQLite，不需要本地数据库）
# 取消注释下面两行并删除 DATABASE_URL
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-token

# Auth 自动生成，无需配置
# 如需固定密钥（推荐），手动设置：
# NEXTAUTH_SECRET=your-random-secret
