# ============== 数据库 ==============
# 本地开发（默认 SQLite）
DB_PROVIDER=sqlite
DATABASE_URL=file:./dev.db

# ============== 平台配置模板 ==============

# --- Vercel ---
# DB_PROVIDER=sqlite                 # Turso（推荐）
# TURSO_DATABASE_URL=libsql://xxx.turso.io
# TURSO_AUTH_TOKEN=your-token
#
# 或 Supabase：
# DB_PROVIDER=postgresql
# DATABASE_URL=postgres://user:pass@host:6543/postgres?pgbouncer=true
# DIRECT_URL=postgres://user:pass@host:5432/postgres

# --- EdgeOne Pages ---
# 同上，Turso 或 Supabase 均可

# --- Cloudflare Pages ---
# 本地使用 wrangler.toml 绑定 D1
# DB_PROVIDER=sqlite
# 无需设置 DATABASE_URL（D1 绑定自动检测）

# ============== Auth ==============
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=your-secret-here
